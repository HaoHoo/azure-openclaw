{
  "meta": {
    "name": "Azure-OpenClaw",
    "version": "1.0.0"
  },
  "models": {
    "mode": "merge",
    "providers": {
      "azure-openai": {
        "baseUrl": "${AZURE_OPENAI_ENDPOINT}/openai/v1",
        "apiKey": "${AZURE_OPENAI_APIKEY}",
        "auth": "api-key",
        "models": [
          {
            "id": "${AZURE_OPENAI_MODEL}",
            "name": "${AZURE_OPENAI_MODEL}(Azure)",
            "api": "openai-completions"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": "azure-openai/${AZURE_OPENAI_MODEL}",
      "workspace": "/home/${adminUserName}/.openclaw/workspace"
    }
  },
  "gateway": {
    "port": "${AZURE_OPENCLAW_PORT}",
    "host": "0.0.0.0",
    "mode": "local",
    "trustProxy": true
  }
}